# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Superdapp integration
SUPERDAPP_API_KEY=
SUPERDAPP_API_URL=https://api.superdapp.com
SUPERDAPP_WEBHOOK_SECRET=replace-with-strong-random-secret
SUPERDAPP_WEBHOOK_PORT=8443
SUPERDAPP_WEBHOOK_PATH=/superdapp/webhook
SUPERDAPP_SEND_ENDPOINT=/messages

# Note: in Railway, PORT is injected by platform and overrides SUPERDAPP_WEBHOOK_PORT

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=Nodaris

# Autonomy mode (optional)
AUTONOMY_ENABLED=false
AUTONOMY_INBOX_PATH=data/inbox
AUTONOMY_SCHEDULER_INTERVAL_SEC=300
AUTONOMY_CONSUMER_BATCH_SIZE=5

# Persistence
AUDIT_DB_PATH=data/nodaris_audits.db
